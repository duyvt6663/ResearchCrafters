// ResearchCrafters relational data model.
//
// Source of truth: backlog/06-data-access-analytics.md.
//
// Conventions:
// - Soft enums via String columns; allowed values documented in the comment
//   above each field. We avoid Prisma `enum` types to keep migration churn
//   low while the product is still moving.
// - JSON columns use Prisma `Json` for flexible payloads mirrored from
//   package YAML or evaluator output.
// - Postgres String[] is used for primitive arrays (e.g. free stage ids).
// - cuid() ids unless otherwise noted.
// - Timestamps: createdAt on every row; updatedAt where the row mutates.
// - Cascading deletes are conservative: enabled for clear ownership chains
//   (Membership -> User, Enrollment -> User, MentorMessage -> Thread, etc.)
//   and disabled for grading/audit chains where we want a paper trail.
//
// PII inventory convention (see backlog/08 §Privacy and Compliance Foundations):
//   Every field that stores personally identifying information, an auth secret,
//   or free-text user-authored content carries a triple-slash JSDoc comment
//   immediately above its declaration in the form:
//
//     /// PII: <category>. Subject to <strategy> on User deletion. <notes>.
//
//   Categories:
//     - "contact identity"      → email, display name, avatar URL.
//     - "auth secret"           → session tokens, OAuth refresh/access tokens.
//     - "provider identifier"   → opaque ids issued by GitHub / OIDC providers.
//     - "user-authored content" → free-text the learner wrote (mentor messages,
//                                 stage answers, share-card insights, review
//                                 notes).
//     - "user-authored artifact pointer" → object-store keys whose target object
//                                 contains user-authored code, logs, or media.
//     - "quasi-PII"             → behavioural rows that, if joined to a userId,
//                                 reconstruct individual activity (events,
//                                 traversals, mentor threads).
//
//   Strategies (formalized in apps/web/lib/account-cascade.ts):
//     - delete    → row is removed when the owning User is deleted.
//     - anonymize → row stays for product/audit reasons; PII fields are nulled
//                   or replaced with `anonymized-${userId}`.
//     - retain    → row stays as part of the audit trail; the userId FK is
//                   nulled where the column is nullable.
//
//   When you add a new column, decide its category up-front and tag it here.
//   Future authors should never have to re-derive the inventory by code search.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Identity & access
// ---------------------------------------------------------------------------

model User {
  id            String   @id @default(cuid())
  /// PII: contact identity. Subject to anonymize on User deletion (set to `anonymized-${userId}@deleted.invalid`). Right-to-erasure target.
  email         String   @unique
  /// PII: contact identity. Subject to anonymize on User deletion (set to null).
  githubHandle  String?
  /// PII: contact identity. Subject to anonymize on User deletion (set to null).
  displayName   String?
  // Auth.js extension: optional display name surfaced by OAuth providers.
  /// PII: contact identity. Subject to anonymize on User deletion (set to null).
  name          String?
  // Auth.js extension: optional avatar URL surfaced by OAuth providers.
  /// PII: contact identity. Subject to anonymize on User deletion (set to null).
  image         String?
  // Auth.js extension: timestamp set when an email magic-link is verified.
  /// PII: contact identity (proof of email control). Subject to anonymize on User deletion (set to null).
  emailVerified DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  memberships   Membership[]
  entitlements  Entitlement[]
  enrollments   Enrollment[]
  shareCards    ShareCard[]
  reviews       Review[]      @relation("ReviewReviewer")
  events        Event[]
  // Auth.js relations.
  accounts      Account[]
  sessions      Session[]
  // CLI device-code flow approvals issued by this user.
  deviceFlows   DeviceCodeFlow[]

  @@index([createdAt])
}

// Auth.js: linked OAuth provider account (e.g. GitHub) for a User.
model Account {
  id                String   @id @default(cuid())
  userId            String
  // Auth.js standard: account type, e.g. 'oauth' | 'oidc' | 'email'.
  type              String
  // Auth.js standard: provider id, e.g. 'github'.
  provider          String
  // Auth.js standard: opaque provider-side account id.
  /// PII: provider identifier. Sometimes a username (GitHub login) and therefore directly identifying. Subject to delete on User deletion (Account row cascades).
  providerAccountId String
  // OAuth refresh token (when issued).
  /// PII: auth secret. Subject to delete on User deletion (Account row cascades). Encryption-at-rest tracked in backlog/08 §Privacy.
  refresh_token     String?
  // OAuth access token (when issued).
  /// PII: auth secret. Subject to delete on User deletion (Account row cascades). Encryption-at-rest tracked in backlog/08 §Privacy.
  access_token      String?
  // OAuth access-token expiry as Unix epoch seconds.
  expires_at        Int?
  // OAuth token type, typically 'bearer'.
  token_type        String?
  // OAuth scope string, space-delimited.
  scope             String?
  // OIDC id_token when the provider issues one.
  /// PII: auth secret. Carries identity claims about the user. Subject to delete on User deletion (Account row cascades). Encryption-at-rest tracked in backlog/08 §Privacy.
  id_token          String?
  // OAuth session_state for OpenID Connect session management.
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Auth.js standard: unique pair scoped per provider.
  @@unique([provider, providerAccountId])
  @@index([userId])
}

// Auth.js: server-side session row when using the database session strategy.
// Also doubles as the bearer-token store for the CLI: the same
// `sessionToken` value is accepted in `Authorization: Bearer <token>` by
// `lib/auth.ts`.
model Session {
  id           String   @id @default(cuid())
  // Auth.js standard: opaque session token stored in the user's cookie.
  /// PII: auth secret. Doubles as the CLI bearer token (see lib/auth.ts). Subject to delete on User deletion (Session row cascades). Anyone holding this string can act as the user until expiry.
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Auth.js: pending email magic-link / verification token.
model VerificationToken {
  // Auth.js standard: identifier is typically the email address.
  /// PII: contact identity. Identifier is the user's email for magic-link flows. No User FK on this row, so the cascade plan must look up by `identifier == user.email` and delete matching rows during account deletion.
  identifier String
  // Auth.js standard: opaque verification token.
  /// PII: auth secret. Anyone holding this token can mint a session for `identifier` until `expires`. Subject to delete on User deletion (matched via identifier).
  token      String   @unique
  expires    DateTime

  // Auth.js standard: composite uniqueness on (identifier, token).
  @@unique([identifier, token])
}

// CLI OAuth device-code flow row. Persists the short-lived state machine for
// `researchcrafters login`: a `pending` flow can be `approved` (by a logged-in
// browser session that hits /auth/device with the matching userCode), `denied`
// by the same surface, or `expired` once `expiresAt` lapses. Once consumed
// (token minted by the CLI poll), `consumedAt` is set so the same deviceCode
// cannot mint a second session.
model DeviceCodeFlow {
  id         String    @id @default(cuid())
  // The CLI-side opaque token. Returned to the CLI from /api/auth/device-code
  // and presented back via /api/auth/device-token.
  /// PII: auth secret. Mints a session for the approving user once consumed. Subject to delete on User deletion (cascade by SetNull on userId then explicit purge of pending flows).
  deviceCode String    @unique
  // The human-readable code shown to the learner (e.g. "ABCD-EFGH"). Entered
  // on the verification page to bind the flow to the active browser session.
  /// PII: auth secret (short-lived pairing code). Subject to delete on User deletion alongside its parent flow row.
  userCode   String    @unique
  // Set when the flow is approved (or denied — we still record who acted).
  userId     String?
  // Allowed values: 'pending' | 'approved' | 'denied' | 'expired'
  state      String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([state, expiresAt])
}

model Membership {
  id         String   @id @default(cuid())
  userId     String
  // Allowed values: 'free' | 'pro' | 'team' | 'institution'
  plan       String
  // Allowed values: 'active' | 'past_due' | 'canceled' | 'paused' | 'trialing'
  status     String
  /// PII: provider identifier. Opaque billing-provider reference (Stripe customer or subscription id). Subject to delete on User deletion (Membership row cascades); upstream billing record must also be canceled out-of-band.
  billingRef String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model Entitlement {
  id                String   @id @default(cuid())
  userId            String
  // Allowed values: 'package' | 'stage' | 'mentor' | 'team_seat'
  scope             String
  packageVersionId  String?
  stageId           String?
  // Allowed values: 'membership' | 'trial' | 'coupon' | 'team' | 'manual'
  source            String
  expiresAt         DateTime?
  createdAt         DateTime @default(now())

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  packageVersion PackageVersion? @relation(fields: [packageVersionId], references: [id], onDelete: SetNull)
  stage          Stage?          @relation(fields: [stageId], references: [id], onDelete: SetNull)

  @@index([userId, scope])
  @@index([packageVersionId])
  @@index([stageId])
}

// ---------------------------------------------------------------------------
// Packages, versions, and patches
// ---------------------------------------------------------------------------

model Package {
  id        String   @id @default(cuid())
  slug      String   @unique
  createdAt DateTime @default(now())

  versions PackageVersion[]
}

model PackageVersion {
  id                   String   @id @default(cuid())
  packageId            String
  version              String
  // Allowed values: 'alpha' | 'beta' | 'live' | 'archived'
  status               String
  sourceHash           String
  manifest             Json
  releaseFreeStageIds  String[] @default([])
  requiresGpu          Boolean  @default(false)
  // Per-package mentor budget caps in USD. `null` means inherit the
  // platform default resolved by `defaultMentorBudgetCaps()`; setting any
  // field pins that scope to a package-specific value enforced by
  // `checkBudget` / `recordMentorRequestSpend` (see
  // `packages/ai/src/cost-cap.ts`).
  mentorBudgetUserDailyUsd Float?
  mentorBudgetPackageUsd   Float?
  mentorBudgetStageUsd     Float?
  createdAt            DateTime @default(now())

  package         Package                 @relation(fields: [packageId], references: [id], onDelete: Cascade)
  patches         PackageVersionPatch[]
  stages          Stage[]
  decisionNodes   DecisionNode[]
  branches        Branch[]
  enrollments     Enrollment[]
  branchStats     BranchStat[]
  shareCards      ShareCard[]
  reviews         Review[]
  events          Event[]
  entitlements    Entitlement[]

  @@unique([packageId, version])
  @@index([status])
}

model PackageVersionPatch {
  id               String   @id @default(cuid())
  packageVersionId String
  patchSeq         Int
  overlays         Json
  createdAt        DateTime @default(now())

  packageVersion PackageVersion @relation(fields: [packageVersionId], references: [id], onDelete: Cascade)

  @@unique([packageVersionId, patchSeq])
  @@index([packageVersionId])
}

// ---------------------------------------------------------------------------
// Mirrored package contents (denormalized index for product queries)
// ---------------------------------------------------------------------------

model Stage {
  id                   String   @id @default(cuid())
  packageVersionId     String
  // The YAML stage id (e.g. "S001"). Unique within a package version.
  stageId              String
  title                String
  // Free-form stage type from the package manifest (e.g. 'lesson', 'lab').
  type                 String
  // 'easy' | 'medium' | 'hard' | other free-form difficulty label.
  difficulty           String
  estimatedTimeMinutes Int
  // Allowed values: 'tests' | 'replay' | 'rubric' | 'mini_experiment'
  validationKind       String
  // Allowed values: 'test' | 'replay' | 'mini_experiment' | 'none'
  runnerMode           String
  rubricRef            String?
  // Mirrored stage policy (entitlement gates, share-card eligibility, etc.).
  stagePolicy          Json
  passThreshold        Float?
  free                 Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  packageVersion PackageVersion @relation(fields: [packageVersionId], references: [id], onDelete: Cascade)
  entitlements   Entitlement[]

  @@unique([packageVersionId, stageId])
  @@index([packageVersionId, stageId])
}

model DecisionNode {
  id               String   @id @default(cuid())
  packageVersionId String
  // The YAML node id (e.g. "N003"). Unique within a package version.
  nodeId           String
  title            String
  // Free-form node type (e.g. 'choice', 'gate', 'milestone').
  type             String
  // Optional reference to the stage this node belongs to (the YAML stage id).
  stageRef         String?
  createdAt        DateTime @default(now())

  packageVersion PackageVersion  @relation(fields: [packageVersionId], references: [id], onDelete: Cascade)
  branches       Branch[]
  traversals     NodeTraversal[]
  branchStats    BranchStat[]

  @@unique([packageVersionId, nodeId])
  @@index([packageVersionId, nodeId])
}

model Branch {
  id                       String   @id @default(cuid())
  packageVersionId         String
  decisionNodeId           String?
  // The YAML branch id. Unique within a package version.
  branchId                 String
  // Allowed values: 'canonical' | 'failed' | 'suboptimal' | 'ambiguous' | 'extension'
  type                     String
  // Allowed values: 'supported' | 'partially_supported' | 'unsupported'
  supportLevel             String
  choice                   String
  evidenceRefs             Json
  sourceRefs               Json?
  lesson                   String
  // Allowed values: 'after_attempt' | 'after_pass' | 'after_completion' | 'always' | 'never'
  gatedFeedbackVisibility  String
  createdAt                DateTime @default(now())

  packageVersion PackageVersion  @relation(fields: [packageVersionId], references: [id], onDelete: Cascade)
  decisionNode   DecisionNode?   @relation(fields: [decisionNodeId], references: [id], onDelete: SetNull)
  traversals     NodeTraversal[]
  attempts       StageAttempt[]

  @@unique([packageVersionId, branchId])
  @@index([packageVersionId, branchId])
  @@index([decisionNodeId])
}

// ---------------------------------------------------------------------------
// Learner progress
// ---------------------------------------------------------------------------

model Enrollment {
  id                  String   @id @default(cuid())
  userId              String
  // Pinned package version. Migrations create a new enrollment.
  packageVersionId    String
  // The active stage's YAML id (Stage.stageId), not the cuid.
  activeStageRef      String?
  // Array of YAML stage ids the learner has completed for this enrollment.
  completedStageRefs  Json     @default("[]")
  // Array of YAML decision node ids that have been unlocked.
  unlockedNodeRefs    Json     @default("[]")
  // Allowed values: 'active' | 'completed' | 'abandoned' | 'migrated'
  status              String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  packageVersion PackageVersion   @relation(fields: [packageVersionId], references: [id], onDelete: Restrict)
  traversals     NodeTraversal[]
  attempts       StageAttempt[]
  mentorThreads  MentorThread[]
  shareCards     ShareCard[]

  @@index([userId, packageVersionId])
  @@index([packageVersionId])
  @@index([status])
}

// Quasi-PII: each NodeTraversal row records "this learner picked this branch at this time" —
// joined to a userId via Enrollment the sequence is individually identifying.
// Subject to delete on User deletion (cascades through Enrollment).
model NodeTraversal {
  id             String   @id @default(cuid())
  enrollmentId   String
  decisionNodeId String
  branchId       String?
  selectedAt     DateTime @default(now())

  enrollment   Enrollment   @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  decisionNode DecisionNode @relation(fields: [decisionNodeId], references: [id], onDelete: Restrict)
  branch       Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull, map: "NodeTraversal_branchId_fkey")

  @@index([enrollmentId])
  @@index([decisionNodeId])
}

model StageAttempt {
  id              String   @id @default(cuid())
  enrollmentId    String
  // The YAML stage id this attempt targets.
  stageRef        String
  /// PII: user-authored content. Free-text learner answers (writing stages, decision rationale, reflection prose). Subject to delete on User deletion (cascades through Enrollment).
  answer          Json
  branchId        String?
  score           Float?
  passed          Boolean  @default(false)
  // Allowed values: 'queued' | 'running' | 'ok' | 'timeout' | 'oom' | 'crash' | 'exit_nonzero' | 'not_required'
  executionStatus String?
  // Convenience pointer to the canonical Grade row (Grade.id).
  gradeId         String?
  createdAt       DateTime @default(now())

  enrollment   Enrollment   @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  branch       Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull, map: "StageAttempt_branchId_fkey")
  submissions  Submission[]
  grades       Grade[]

  @@index([enrollmentId, stageRef])
  @@index([createdAt])
}

model Submission {
  id              String   @id @default(cuid())
  stageAttemptId  String
  /// PII: user-authored artifact pointer. References an S3 object containing the learner's code bundle. Submissions are an audit artifact — DB row is retained on User deletion with the parent enrollment torn down via Restrict, but the underlying S3 object is purged out-of-band per backlog/06 retention. Cascade strategy: retain (FK to attempt is Restrict); the deletion plan removes the Submission row explicitly after dependent Run/Grade rows are cleared.
  bundleObjectKey String
  bundleSha       String
  byteSize        Int
  fileCount       Int
  createdAt       DateTime @default(now())

  // Conservative: do NOT cascade Submission deletes. Submissions are an
  // audit artifact — losing them silently when an attempt is removed would
  // be the wrong default.
  stageAttempt StageAttempt @relation(fields: [stageAttemptId], references: [id], onDelete: Restrict)
  runs         Run[]
  grades       Grade[]

  @@index([stageAttemptId])
  @@index([bundleSha])
}

model Run {
  id           String    @id @default(cuid())
  submissionId String
  // Allowed values: 'queued' | 'running' | 'ok' | 'timeout' | 'oom' | 'crash' | 'exit_nonzero'
  status       String
  // Allowed values: 'test' | 'replay' | 'mini_experiment' | 'none'
  runnerMode   String
  /// PII: user-authored artifact pointer. References the S3 log of the run; logs may include user-authored print statements / stack traces that mention learner identifiers. Subject to delete on User deletion (cascades when the Submission is removed via the explicit cascade plan); S3 object purged out-of-band.
  logObjectKey String?
  metricsJson  Json?
  startedAt    DateTime?
  finishedAt   DateTime?
  createdAt    DateTime  @default(now())

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Restrict)

  @@index([submissionId])
  @@index([status, createdAt])
}

model Grade {
  id               String   @id @default(cuid())
  stageAttemptId   String
  submissionId     String?
  rubricVersion    String
  evaluatorVersion String
  passed           Boolean  @default(false)
  score            Float?
  dimensions       Json
  evidenceRefs     Json
  modelMeta        Json?
  // Append-only history of overrides; never mutated in place.
  history          Json     @default("[]")
  createdAt        DateTime @default(now())

  stageAttempt StageAttempt @relation(fields: [stageAttemptId], references: [id], onDelete: Restrict)
  submission   Submission?  @relation(fields: [submissionId], references: [id], onDelete: SetNull)

  // Idempotency: at most one grade per (submission, rubric, evaluator) tuple.
  @@unique([submissionId, rubricVersion, evaluatorVersion])
  @@index([stageAttemptId])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Mentor
// ---------------------------------------------------------------------------

// Quasi-PII: a MentorThread row indicates that a specific learner sought mentor
// help on a specific stage. Subject to delete on User deletion (cascades
// through Enrollment); messages cascade through the thread.
model MentorThread {
  id           String   @id @default(cuid())
  enrollmentId String
  // The YAML stage id this thread is scoped to.
  stageRef     String
  createdAt    DateTime @default(now())

  enrollment Enrollment      @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  messages   MentorMessage[]

  @@index([enrollmentId, stageRef])
}

model MentorMessage {
  id                  String   @id @default(cuid())
  threadId            String
  // Allowed values: 'user' | 'assistant' | 'system'
  role                String
  // NOTE: bodyText is sensitive (mentor transcripts) — encryption-at-rest is
  // tracked in backlog/08 §Privacy. Stored as plaintext in dev for now.
  /// PII: user-authored content. Free-text mentor transcripts (user role) and the model-generated coaching response (assistant role) referencing the user's prose. Subject to delete on User deletion (cascades through MentorThread → Enrollment).
  bodyText            String
  // Free-form tier label (e.g. 'fast' | 'deep' | 'guard').
  modelTier           String?
  modelId             String?
  provider            String?
  promptTokens        Int?
  completionTokens    Int?
  redactionTriggered  Boolean  @default(false)
  flagged             Boolean  @default(false)
  createdAt           DateTime @default(now())

  thread MentorThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
  @@index([flagged])
}

// ---------------------------------------------------------------------------
// Analytics & sharing
// ---------------------------------------------------------------------------

model BranchStat {
  id               String   @id @default(cuid())
  packageVersionId String
  decisionNodeId   String
  // YAML branch id (Branch.branchId), not the cuid, so rollups stay stable
  // across schema reshuffles.
  branchId         String
  // Allowed values: 'all_attempts' | 'completers' | 'entitled_paid' | 'alpha_beta'
  cohort           String
  windowStart      DateTime
  windowEnd        DateTime
  n                Int
  percent          Float?
  createdAt        DateTime @default(now())

  packageVersion PackageVersion @relation(fields: [packageVersionId], references: [id], onDelete: Cascade)
  decisionNode   DecisionNode   @relation(fields: [decisionNodeId], references: [id], onDelete: Cascade)

  @@index([packageVersionId, decisionNodeId, branchId, cohort, windowStart])
}

model ShareCard {
  id               String   @id @default(cuid())
  userId           String
  enrollmentId     String
  packageVersionId String
  // Immutable snapshot of ShareCardPayload from docs/TECHNICAL.md §5.
  /// PII: user-authored content. May embed the learner's hand-written insight and other identifying fields (display name, hardest decision phrasing). Subject to delete on User deletion (cascades through ShareCard → User).
  payload          Json
  // Set when the share card has a public URL; unique only when present.
  /// PII: indirectly identifying. A public slug, once published, becomes a URL the learner may have shared externally; we delete the row on account deletion so the URL 404s.
  publicSlug       String?  @unique
  createdAt        DateTime @default(now())

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  enrollment     Enrollment     @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  packageVersion PackageVersion @relation(fields: [packageVersionId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([enrollmentId])
  @@index([packageVersionId])
}

model Review {
  id               String   @id @default(cuid())
  packageVersionId String
  reviewerId       String?
  // Allowed values: 'pending' | 'approved' | 'rejected'
  status           String
  /// PII: user-authored content (reviewer prose). Subject to retain on reviewer deletion (Review row stays; reviewerId nulls via SetNull) so package moderation history is preserved; the prose itself rarely names the reviewer but may be quoted in audit reviews.
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  packageVersion PackageVersion @relation(fields: [packageVersionId], references: [id], onDelete: Cascade)
  reviewer       User?          @relation("ReviewReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)

  @@index([packageVersionId])
  @@index([status])
}

// Quasi-PII when joined to userId. Audit-grade rows (auditGrade=true) are
// retained indefinitely per backlog/06 §Events Storage; non-audit rows are
// scrubbed to anonymized aggregates after 24 months. On User deletion the
// strategy is `retain` — events stay but the userId FK is nulled (SetNull)
// so the audit trail of grading / payments / moderation actions survives
// without a back-reference to the deleted account.
model Event {
  id               String   @id @default(cuid())
  // Telemetry name (e.g. 'grade_created'). See docs/TECHNICAL.md §5
  // taxonomy and backlog/06 §Events Storage for audit-grade rules.
  name             String
  /// PII: foreign key to a deleted user is kept as null after account deletion (SetNull). The row itself remains for the audit retention window.
  userId           String?
  packageVersionId String?
  // YAML stage id, when relevant.
  stageRef         String?
  /// PII: variable. Payload may carry user-authored snippets for some event types; emitters MUST avoid embedding raw PII here. The deletion plan does not scrub historical payloads — owners of new event types are responsible for keeping payloads PII-free.
  payload          Json
  // True for events that affect entitlement, grading, mentor policy,
  // payments, or moderation. Retained indefinitely.
  auditGrade       Boolean  @default(false)
  createdAt        DateTime @default(now())

  user           User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  packageVersion PackageVersion? @relation(fields: [packageVersionId], references: [id], onDelete: SetNull)

  @@index([name, createdAt])
  @@index([userId, createdAt])
  @@index([auditGrade, createdAt])
}
