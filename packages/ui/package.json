{
  "name": "@researchcrafters/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": [
    "./dist/styles.css",
    "./src/styles.css"
  ],
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./tokens": {
      "types": "./dist/tokens.d.ts",
      "default": "./dist/tokens.js"
    },
    "./copy": {
      "types": "./dist/copy/index.d.ts",
      "default": "./dist/copy/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "default": "./dist/components/index.js"
    },
    "./cli-commands": {
      "types": "./dist/cli-commands.d.ts",
      "default": "./dist/cli-commands.js"
    },
    "./styles.css": "./src/styles.css"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.5",
    "lucide-react": "^0.468.0",
    "shiki": "^1.24.0",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-tooltip": "^1.1.6"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^2.1.8",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@researchcrafters/config": "workspace:*"
  }
}
