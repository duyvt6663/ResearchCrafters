{
  "name": "@researchcrafters/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./admin": "./src/admin.ts",
    "./scheduler": "./src/scheduler.ts"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "start:traced": "node --import ./instrumentation.ts dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "lint": "eslint ."
  },
  "dependencies": {
    "@researchcrafters/db": "workspace:*",
    "@researchcrafters/telemetry": "workspace:*",
    "@vercel/otel": "^1.13.0",
    "@opentelemetry/api": "^1.9.0",
    "bullmq": "^5.21.0",
    "ioredis": "^5.4.1"
  },
  "devDependencies": {
    "@researchcrafters/config": "workspace:*",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
