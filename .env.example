# Copy to .env and fill in. Local-dev defaults match docker-compose.yml.

# Prisma connection string for the dev Postgres container.
DATABASE_URL=postgresql://researchcrafters:researchcrafters@localhost:5432/researchcrafters?schema=public

# Redis URL used by BullMQ workers and rate limiters.
REDIS_URL=redis://localhost:6379

# MinIO S3 emulator API endpoint.
S3_ENDPOINT=http://localhost:9000

# MinIO root credentials (matches MINIO_ROOT_USER / MINIO_ROOT_PASSWORD in docker-compose).
S3_ACCESS_KEY=researchcrafters

# MinIO root secret.
S3_SECRET_KEY=researchcrafters

# Bucket holding learner submission tarballs.
S3_BUCKET_SUBMISSIONS=researchcrafters-submissions

# Bucket holding runner output (logs, artifacts).
S3_BUCKET_RUNS=researchcrafters-runs

# Bucket holding built ERP packages and starter workspaces.
S3_BUCKET_PACKAGES=researchcrafters-packages

# Bucket holding rendered share-card images.
S3_BUCKET_SHARE_CARDS=researchcrafters-share-cards

# Public base URL the CLI uses to reach the web API.
RESEARCHCRAFTERS_API_URL=http://localhost:3000

# NextAuth canonical URL for callback construction.
NEXTAUTH_URL=http://localhost:3000

# NextAuth session-cookie secret. Replace with a 32+ byte random string before any non-local use.
NEXTAUTH_SECRET=replace-me

# GitHub OAuth app client id for the "Sign in with GitHub" flow.
GITHUB_OAUTH_CLIENT_ID=

# GitHub OAuth app client secret.
GITHUB_OAUTH_CLIENT_SECRET=

# Anthropic API key for the mentor LLM gateway. Intentionally blank — leaving this unset is the runtime safety stop that disables real mentor calls.
ANTHROPIC_API_KEY=

# Set to "true" only when you have a hardened Docker daemon available; the runner refuses to spawn sandboxes otherwise.
RUNNER_DOCKER_ENABLED=false

# PostHog project API key for product analytics. Leave blank to disable telemetry locally.
POSTHOG_API_KEY=
